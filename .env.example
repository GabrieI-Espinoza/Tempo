# Example environment variables for PostgreSQL configuration
# Replace the placeholder values with your actual database credentials
POSTGRES_USER=some_user
POSTGRES_PASSWORD=some_password

POSTGRES_DB=some_db
POSTGRES_HOST=some_host

POSTGRES_PORT=some_port
DATABASE_URL=postgres://some_user:some_password@some_host:some_port/some_db

# Example application settings
JWT_SECRET=your_jwt_secret_key_here
CORS_ORIGINS=["http://example:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=0